<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<FilesMatch "(\.env|composer\.json|composer\.lock|package\.json|package-lock\.json|artisan|server\.php)$">
    Require all denied
</FilesMatch>

Options -Indexes

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
